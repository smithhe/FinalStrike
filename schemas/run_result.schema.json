        "status"
      ],
      "title": "BuildLayerResult",
      "type": "object"
    },
    "EnvLayerResult": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/LayerStatus"
        },
        "duration_ms": {
          "title": "Duration Ms",
          "type": "integer"
