      "required": [
        "status"
      ],
      "title": "APILayerResult",
      "type": "object"
    },
    "BuildCommandResult": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/LayerStatus"
        },
        "exit_code": {
          "title": "Exit Code",
          "type": "integer"
        },
        "duration_ms": {
          "title": "Duration Ms",
          "type": "integer"
        },
        "stdout": {
          "default": "",
          "title": "Stdout",
          "type": "string"
        },
        "stderr": {
          "default": "",
          "title": "Stderr",
          "type": "string"
        }
      },
      "required": [
        "name",
        "status",
        "exit_code",
        "duration_ms"
