    "RunStatus": {
      "enum": [
        "passed",
        "failed",
        "partial"
      ],
      "title": "RunStatus",
      "type": "string"
    },
    "TerminalCommandResult": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/LayerStatus"
        },
        "exit_code": {
          "title": "Exit Code",
          "type": "integer"
        },
        "duration_ms": {
          "title": "Duration Ms",
          "type": "integer"
        },
        "total_passed": {
          "default": 0,
          "title": "Total Passed",
          "type": "integer"
        },
        "total_failed": {
          "default": 0,
          "title": "Total Failed",
          "type": "integer"
        },
        "stdout": {
          "default": "",
          "title": "Stdout",
          "type": "string"
        },
        "stderr": {
          "default": "",
          "title": "Stderr",
          "type": "string"
        }
