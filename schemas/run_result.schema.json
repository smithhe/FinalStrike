    "UIStepResult": {
      "additionalProperties": false,
      "properties": {
        "step_index": {
          "title": "Step Index",
          "type": "integer"
        },
        "action": {
          "title": "Action",
          "type": "string"
        },
        "screenshot": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
