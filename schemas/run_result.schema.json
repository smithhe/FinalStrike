{
  "$defs": {
    "APICheckResult": {
      "additionalProperties": false,
      "properties": {
        "method": {
          "title": "Method",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/LayerStatus"
        },
        "expected_status": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Status"
        },
        "actual_status": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Actual Status"
        },
        "duration_ms": {
          "default": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "response_body": {
          "default": "",
          "title": "Response Body",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "required": [
        "method",
        "path",
        "status"
      ],
      "title": "APICheckResult",
      "type": "object"
    },
    "APILayerResult": {
      "additionalProperties": false,
      "properties": {
        "status": {
