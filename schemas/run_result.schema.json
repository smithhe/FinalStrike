  "additionalProperties": false,
  "description": "Canonical evidence bundle output for a verification run.",
  "properties": {
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "repo": {
      "title": "Repo",
      "type": "string"
    },
    "branch": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Branch"
    },
    "status": {
      "$ref": "#/$defs/RunStatus"
    },
    "layers": {
      "$ref": "#/$defs/RunLayers"
    },
    "artifacts": {
      "$ref": "#/$defs/RunArtifacts"
    },
    "gaps": {
      "items": {
        "$ref": "#/$defs/PlanGap"
      },
      "title": "Gaps",
      "type": "array"
    }
